    </Content>
    <Content Include="Assets\Wide310x150Logo.scale-200.png">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
  </ItemGroup>

  <ItemGroup>
    <Manifest Include="$(ApplicationManifest)" />
  </ItemGroup>

  <!-- The handbook generator is a standalone build tool; keep its sources out of the app build. -->
  <ItemGroup>
    <Compile Remove="tools\**" />
    <Content Remove="tools\**" />
    <None Remove="tools\**" />
    <Page Remove="tools\**" />
  </ItemGroup>

  <!-- Handbook PDF, generated from docs/Handbook.md, shipped next to the exe. Remove from the
       default None glob first, then include as copied Content (same pattern as the image assets). -->
  <ItemGroup>
    <None Remove="Assets\Handbook.pdf" />
    <!-- Link places the loose copy at the output root (next to ttm.exe), not under Assets\. -->
    <Content Include="Assets\Handbook.pdf" Link="Handbook.pdf">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
  </ItemGroup>

  <!-- Ship the LICENSE next to the exe so Help ▸ About can display it. -->
  <ItemGroup>
    <None Remove="LICENSE" />
    <Content Include="LICENSE">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
  </ItemGroup>

  <!-- Regenerate the handbook when the markdown changes. ContinueOnError keeps the app build
       working offline / if the tool can't restore — the last committed PDF is used then. -->
  <Target Name="GenerateHandbook" BeforeTargets="BeforeBuild"
          Inputs="docs\Handbook.md" Outputs="Assets\Handbook.pdf">
    <Exec ContinueOnError="true"
          Command="dotnet run --project &quot;$(MSBuildProjectDirectory)\tools\HandbookGen\HandbookGen.csproj&quot; -c Release -- &quot;$(MSBuildProjectDirectory)\docs\Handbook.md&quot; &quot;$(MSBuildProjectDirectory)\Assets\Handbook.pdf&quot; &quot;$(Version)&quot;" />
  </Target>

  <!-- Bundled TipTap editor assets (built from /editor via `npm run build`). -->
  <ItemGroup>
    <Content Include="Assets\editor\**\*.*">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
  </ItemGroup>

  <!--
    Defining the "Msix" ProjectCapability here allows the Single-project MSIX Packaging
