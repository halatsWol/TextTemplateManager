<Page
    x:Class="TextTemplateManager.SyncSettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:TextTemplateManager.Models"
    xmlns:helpers="using:TextTemplateManager.Helpers">

    <Page.Resources>
        <helpers:BoolToVisibilityConverter x:Key="BoolToVis"/>
    </Page.Resources>

    <Grid Padding="20" RowSpacing="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Title + separator setting, with the help button pinned top-right -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Spacing="10">
                <TextBlock Text="Sync" Style="{StaticResource TitleTextBlockStyle}"/>
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBlock Text="Shortcut prefix separator" VerticalAlignment="Center"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    <!-- Value is mapped by index: 0='-', 1='.', 2=none (""). See the code-behind. -->
                    <ComboBox x:Name="SeparatorBox" Width="96"
                              SelectionChanged="Separator_SelectionChanged">
                        <ComboBoxItem Content="-"/>
                        <ComboBoxItem Content="."/>
                        <ComboBoxItem>
                            <!-- Right padding keeps the italic slant of "none" from clipping when selected. -->
                            <TextBlock Text="none" FontStyle="Italic" Padding="0,0,4,0"/>
                        </ComboBoxItem>
                    </ComboBox>
                </StackPanel>
            </StackPanel>
            <Button x:Name="SyncHelpButton" Grid.Column="1" VerticalAlignment="Top" HorizontalAlignment="Right"
                    Click="SyncHelpButton_Click" ToolTipService.ToolTip="Quick Help" Style="{StaticResource SubtleButtonStyle}">
                <FontIcon Glyph="&#xE897;"/>
            </Button>
        </Grid>

        <!-- Toolbar: add existing / create new -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
            <Button Content="Add" Click="AddExisting_Click" ToolTipService.ToolTip="Link an existing .ttmdata sync file"/>
            <Button Content="Create" Click="CreateNew_Click"
                    ToolTipService.ToolTip="Create a new sync file"/>
        </StackPanel>

        <TeachingTip x:Name="SyncHelpTip" Title="Sync Guide" Target="{x:Bind SyncHelpButton}"
                     PreferredPlacement="BottomLeft" IsLightDismissEnabled="True">
            <TeachingTip.Content>
                <Grid MaxWidth="360" Margin="0,4" ColumnSpacing="8" RowSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="➕" VerticalAlignment="Top"/>
                    <TextBlock Grid.Row="0" Grid.Column="1" TextWrapping="Wrap" FontSize="13">
                        <Run FontWeight="SemiBold" Text="Add a source:"/><Run Text=" link an existing .ttmdata file, or Create a new one (e.g. inside a OneDrive folder to sync across PCs)."/>
                    </TextBlock>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="✅" VerticalAlignment="Top"/>
                    <TextBlock Grid.Row="1" Grid.Column="1" TextWrapping="Wrap" FontSize="13">
                        <Run FontWeight="SemiBold" Text="Active:"/><Run Text=" load the source as a pinned top-level folder. Uncheck to hide it without deleting."/>
                    </TextBlock>

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="💾" VerticalAlignment="Top"/>
                    <TextBlock Grid.Row="2" Grid.Column="1" TextWrapping="Wrap" FontSize="13">
                        <Run FontWeight="SemiBold" Text="Save:"/><Run Text=" on = editable and your changes write back to the file; off = read-only (the file always wins on reload)."/>
                    </TextBlock>

                    <TextBlock Grid.Row="3" Grid.Column="0" Text="🏷️" VerticalAlignment="Top"/>
                    <TextBlock Grid.Row="3" Grid.Column="1" TextWrapping="Wrap" FontSize="13">
                        <Run FontWeight="SemiBold" Text="Name &amp; Prefix:"/><Run Text=" Name is the folder's local title. Prefix namespaces its multi-key shortcuts, e.g. prefix 'and' + 'msg' is typed as and-msg."/>
                    </TextBlock>

                    <TextBlock Grid.Row="4" Grid.Column="0" Text="↕️" VerticalAlignment="Top"/>
                    <TextBlock Grid.Row="4" Grid.Column="1" TextWrapping="Wrap" FontSize="13">
                        <Run FontWeight="SemiBold" Text="Order:"/><Run Text=" the arrows set folder priority — for a single key shared across areas, the first source here wins after local. Applies immediately."/>
                    </TextBlock>

                    <TextBlock Grid.Row="5" Grid.Column="0" Text="⚠" VerticalAlignment="Top" FontWeight="SemiBold"/>
                    <TextBlock Grid.Row="5" Grid.Column="1" TextWrapping="Wrap" FontSize="13">
                        <Run FontWeight="SemiBold" Text="Missing file:"/><Run Text=" a warning icon appears — click it to re-link. The cached copy stays visible meanwhile."/>
                    </TextBlock>

                    <TextBlock Grid.Row="6" Grid.Column="0" Text="🔤" VerticalAlignment="Top"/>
                    <TextBlock Grid.Row="6" Grid.Column="1" TextWrapping="Wrap" FontSize="13">
                        <Run FontWeight="SemiBold" Text="Separator:"/><Run Text=" the character joining a prefix to a shortcut (default '-'). Choose '-', '.', or none (the prefix joins the shortcut directly, e.g. ANDMSG)."/>
                    </TextBlock>
                </Grid>
            </TeachingTip.Content>
        </TeachingTip>

        <!-- Column headers -->
        <Grid Grid.Row="2" ColumnSpacing="8" Padding="8,0,8,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="56"/>
                <ColumnDefinition Width="56"/>
                <ColumnDefinition Width="150"/>
                <ColumnDefinition Width="90"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Active" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            <TextBlock Grid.Column="1" Text="Save" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            <TextBlock Grid.Column="2" Text="Name" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            <TextBlock Grid.Column="3" Text="Prefix" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            <TextBlock Grid.Column="4" Text="File" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
        </Grid>

        <!-- Source list -->
        <ListView Grid.Row="3" x:Name="SourceList" SelectionMode="None">
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    <Setter Property="Padding" Value="8,4"/>
                    <Setter Property="MinHeight" Value="0"/>
                </Style>
            </ListView.ItemContainerStyle>
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="models:SyncSource">
                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="56"/>
                            <ColumnDefinition Width="56"/>
                            <ColumnDefinition Width="150"/>
                            <ColumnDefinition Width="90"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <CheckBox Grid.Column="0" MinWidth="0" IsChecked="{x:Bind IsActive, Mode=TwoWay}"
                                  ToolTipService.ToolTip="Active (loaded into the tree)"/>
                        <CheckBox Grid.Column="1" MinWidth="0" IsChecked="{x:Bind AllowSave, Mode=TwoWay}"
                                  ToolTipService.ToolTip="Allow save (editable / writes back)"/>
                        <TextBox Grid.Column="2" Text="{x:Bind Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 PlaceholderText="Folder name"/>
                        <TextBox Grid.Column="3" Text="{x:Bind ShortcutPrefix, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 TextChanged="Prefix_TextChanged" PlaceholderText="PREFIX"/>

                        <StackPanel Grid.Column="4" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                            <Button Padding="4" Background="Transparent" BorderThickness="0"
                                    Visibility="{x:Bind IsFileMissing, Mode=OneWay, Converter={StaticResource BoolToVis}}"
                                    Click="Relink_Click"
                                    ToolTipService.ToolTip="File not found — click to re-link">
                                <FontIcon Glyph="&#xE7BA;" Foreground="#E6A700" FontSize="16"/>
                            </Button>
                            <TextBlock Text="{x:Bind Path, Mode=OneWay}" TextTrimming="CharacterEllipsis"
                                       VerticalAlignment="Center"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="5" Orientation="Horizontal" Spacing="2" VerticalAlignment="Center">
                            <Button Click="MoveUp_Click" Padding="6" ToolTipService.ToolTip="Move up">
                                <FontIcon Glyph="&#xE70E;" FontSize="14"/>
                            </Button>
                            <Button Click="MoveDown_Click" Padding="6" ToolTipService.ToolTip="Move down">
                                <FontIcon Glyph="&#xE70D;" FontSize="14"/>
                            </Button>
                            <Button Click="Remove_Click" Padding="6" ToolTipService.ToolTip="Remove">
                                <FontIcon Glyph="&#xE74D;" FontSize="14"/>
                            </Button>
                        </StackPanel>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>
