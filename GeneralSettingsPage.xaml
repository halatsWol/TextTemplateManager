<Page
    x:Class="TextTemplateManager.GeneralSettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:common="using:TextTemplateManager.Common">

    <ScrollViewer VerticalScrollBarVisibility="Auto" VerticalScrollMode="Auto">
    <StackPanel Spacing="25" Padding="20">
        <TextBlock Text="General Settings" Style="{StaticResource TitleTextBlockStyle}"/>

        <ToggleSwitch Header="Run at Windows Login"
                      IsOn="{x:Bind ViewModel.RunAtStartup, Mode=TwoWay}"
                      Toggled="RunAtStartup_Toggled"/>

        <StackPanel Spacing="10">
            <ToggleSwitch x:Name="AutoUpdateToggle"
                          Header="Automatically check for updates"
                          Toggled="AutoUpdate_Toggled"/>

            <StackPanel Spacing="2">
                <ToggleSwitch x:Name="BetaToggle"
                              Header="Allow beta updates"
                              Toggled="Beta_Toggled"/>
                <TextBlock Text="Also offer pre-release versions (beta / preview). Off = stable releases only."
                           Style="{StaticResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            </StackPanel>

            <!-- Shown only when an enterprise policy (registry) restricts updates. -->
            <TextBlock x:Name="UpdatePolicyNote"
                       Visibility="Collapsed"
                       TextWrapping="Wrap"
                       Style="{StaticResource CaptionTextBlockStyle}"
                       Foreground="{ThemeResource SystemFillColorCautionBrush}"/>
        </StackPanel>

        <Rectangle Height="1" Fill="{ThemeResource SystemControlForegroundBaseLowBrush}" Margin="0,5"/>

        <StackPanel Spacing="8">
            <TextBlock Text="Default Paste Mode" Style="{StaticResource BodyStrongTextBlockStyle}"/>
            <TextBlock Text="Sets the mode used when creating new templates." Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            <ComboBox x:Name="PasteModeCombo"
                      MinWidth="200"
                      SelectedItem="{x:Bind ViewModel.DefaultPasteMode, Mode=TwoWay}">
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding Converter={StaticResource PasteModeLabelConverter}}"/>
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>
        </StackPanel>

        <StackPanel Spacing="8">
            <TextBlock Text="Global Shortcut" Style="{StaticResource BodyStrongTextBlockStyle}"/>
            <TextBlock Text="Hotkey to open the Quick Paste window from anywhere." Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            <Grid ColumnSpacing="10" HorizontalAlignment="Left">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="HotkeyTextBox"
                         IsReadOnly="True"
                         PlaceholderText="Click to set shortcut..."
                         GotFocus="HotkeyTextBox_GotFocus"
                         LostFocus="HotkeyTextBox_LostFocus"
                         KeyDown="HotkeyTextBox_KeyDown"
                         KeyUp="HotkeyTextBox_KeyUp"/>
                <Button Grid.Column="1" Content="Clear" Click="ClearHotkey_Click"/>
            </Grid>
        </StackPanel>

        <StackPanel Spacing="2">
            <ToggleSwitch x:Name="HideCrossAreaWarningsToggle"
                          Header="Hide cross-area shortcut warnings"
                          IsOn="{x:Bind ViewModel.HideCrossAreaShortcutWarnings, Mode=TwoWay}"
                          Toggled="HideCrossAreaWarnings_Toggled"/>
            <TextBlock Text="Don't show the dismissible notice when the same shortcut is used in more than one area (local + sync, or across sync folders). Blocking same-area duplicates are still shown."
                       TextWrapping="Wrap"
                       Style="{StaticResource CaptionTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
        </StackPanel>

        <Rectangle Height="1" Fill="{ThemeResource SystemControlForegroundBaseLowBrush}" Margin="0,5"/>

        <StackPanel Spacing="8">
            <TextBlock Text="Browser extensions (beta)" Style="{StaticResource BodyStrongTextBlockStyle}"/>
            <TextBlock TextWrapping="Wrap" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       Text="Lets a companion browser extension list and paste your templates over a local (127.0.0.1) connection. Off by default; paste the token below into the extension to pair it."/>
            <ToggleSwitch x:Name="ConnectorToggle" Header="Enable browser connector" Toggled="Connector_Toggled"/>

            <StackPanel Spacing="2">
                <TextBlock Text="Get the extension:" Style="{StaticResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                <StackPanel Margin="12,0,0,0" Spacing="2">
                    <HyperlinkButton Content="Chrome Web Store"
                                     NavigateUri="https://chrome.google.com/webstore/detail/jclopjpjdldbknjdhmjldehlkgbihlmi"
                                     Padding="0"/>
                    <TextBlock Text="Microsoft Edge — coming soon" Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    <HyperlinkButton Content="Firefox Add-ons"
                                     NavigateUri="https://addons.mozilla.org/addon/ttm-connect/"
                                     Padding="0"/>
                </StackPanel>
            </StackPanel>
            <HyperlinkButton x:Name="ApiDocLink" Content="View API documentation" Padding="0"/>

            <Grid x:Name="ConnectorDetails" Visibility="Collapsed" ColumnSpacing="10" RowSpacing="8" HorizontalAlignment="Left">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="280"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="Port" VerticalAlignment="Center"/>
                <TextBox Grid.Row="0" Grid.Column="1" x:Name="ConnectorPortBox" HorizontalAlignment="Left" MinWidth="90"
                         InputScope="Number" LostFocus="ConnectorPort_LostFocus"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="Token" VerticalAlignment="Center"/>
                <TextBox Grid.Row="1" Grid.Column="1" x:Name="ConnectorTokenBox" IsReadOnly="True" IsSpellCheckEnabled="False"/>
                <Button Grid.Row="1" Grid.Column="2" Content="Copy" Click="CopyToken_Click"/>
                <Button Grid.Row="1" Grid.Column="3" Content="Regenerate" Click="RegenerateToken_Click"/>
            </Grid>
        </StackPanel>

        <Rectangle Height="1" Fill="{ThemeResource SystemControlForegroundBaseLowBrush}" Margin="0,5"/>

        <StackPanel Spacing="8">
            <TextBlock Text="File association" Style="{StaticResource BodyStrongTextBlockStyle}"/>
            <TextBlock TextWrapping="Wrap" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       Text="Make .ttmdata files open with Text Template Manager (opening one adds it as a sync source). Use this if another app took over the association."/>
            <Button Content="Set as default for .ttmdata" Click="RegisterFileType_Click" HorizontalAlignment="Left"/>
            <InfoBar x:Name="FileAssocInfo" IsOpen="False" IsClosable="True"/>
        </StackPanel>
    </StackPanel>
    </ScrollViewer>
</Page>